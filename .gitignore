# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# claude code (config local)
.claude/

# typescript
*.tsbuildinfo
next-env.d.ts

# foundry
/contracts/cache/
/contracts/out/
/contracts/lib/

# foundry — deploys: ignora simulaciones y red local; conserva deploys reales
/contracts/broadcast/**/dry-run/
/contracts/broadcast/**/31337/
!/contracts/broadcast/**/31337/run-latest.json

# docs de contexto de sesión (local, no se versionan)
docs/sesion-*.md

# marketing (plan local, no se versiona)
/marketing/

# funding (aplicaciones a financiamiento, privadas — no se versionan)
/funding/

# artefactos del pitch (binarios pesados / entorno local, no se versionan)
docs/.venv/
docs/.export-slides/
docs/reyf-pitch-kit/
docs/reyf-pitch-kit.zip
docs/reyf-pitch.pptx
docs/reyf-demo.mp4
