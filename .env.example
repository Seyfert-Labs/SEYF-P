# ============================================================
# Reyf — Variables de entorno
# Copia este archivo como .env.local y rellena tus credenciales.
# .env.local NO se sube al repo (ver .gitignore).
# ============================================================

# --- Credenciales de Juno / Bitso Business (SOLO server-side) ---
# Obtén tus llaves en: https://stage.buildwithjuno.com (entorno stage)
# IMPORTANTE: nunca uses el prefijo NEXT_PUBLIC_ para estas llaves.
BITSO_APIKEY=tu_api_key_de_juno
BITSO_SECRET_APIKEY=tu_api_secret_de_juno

# URL base de la API de Juno (default: entorno stage).
# Producción: https://buildwithjuno.com
JUNO_BASE_URL=https://stage.buildwithjuno.com

# URL base de la Bitso Exchange API (FX/órdenes). Mismo esquema HMAC y mismas
# llaves (BITSO_APIKEY/SECRET). Default: stage. Producción: https://api.bitso.com
BITSO_BASE_URL=https://stage.bitso.com

# Secreto para verificar la firma de los webhooks de Juno/Bitso.
# Encuéntralo en: Dashboard Juno → Configuración → Webhooks → Secret.
# Si se omite, el webhook acepta cualquier llamada (solo para desarrollo).
JUNO_WEBHOOK_SECRET=

# Bono de bienvenida (Juno emite MXNB on-chain a usuarios nuevos en testnet).
WELCOME_BONUS_AMOUNT=1500
# Activo y red para el withdrawal on-chain (Juno valida: asset=MXNB, blockchain=ARBITRUM).
JUNO_WITHDRAWAL_ASSET=MXNB
JUNO_BLOCKCHAIN=ARBITRUM

# --- Wallets sociales (Privy) ---
# App ID gratis en https://dashboard.privy.io  (habilita Google + Email).
# Sin este valor, la app corre en modo demo (sin login ni wallet real).
NEXT_PUBLIC_PRIVY_APP_ID=

# --- Red / token MXNB (cliente) ---
# Red: "arbitrum-sepolia" (testnet, default) o "arbitrum" (mainnet).
NEXT_PUBLIC_CHAIN=arbitrum-sepolia
# Dirección del contrato MXNB (proxy). Si se omite, se usa la oficial según la red:
#   testnet (Arbitrum Sepolia): 0x82B9e52b26A2954E113F94Ff26647754d5a4247D
#   mainnet (Arbitrum One):     0xF197FFC28c23E0309B5559e7a166f2c6164C80aA
NEXT_PUBLIC_MXNB_ADDRESS=
# RPC personalizado de Arbitrum (opcional; por defecto usa el público de la red).
NEXT_PUBLIC_ARBITRUM_RPC=

# --- Bóvedas on-chain (contrato ReyfVaults) ---
# Dirección del contrato ReyfVaults ya desplegado (ver contracts/README.md).
# Si se omite, las bóvedas usan la capa `store` (Supabase/localStorage).
# Con valor presente, las bóvedas son reales on-chain (abrir/abonar/retirar MXNB).
# Desplegado en Arbitrum Sepolia: 0x0212d50490FE5D7183B5B3A403d5C44937a44cF1
NEXT_PUBLIC_SEYF_VAULTS_ADDRESS=

# --- Adelanto de liquidez on-chain (contrato ReyfAdvance) ---
# Modelo por AÑOS (hasta LTV 90%). Si la dirección es la legacy v1
# (0x6C9b17C9…), el front solo puede adelantar ~1 año hasta redesplegar:
#   cd contracts && ./scripts/redeploy-advance-sepolia.sh
NEXT_PUBLIC_SEYF_ADVANCE_ADDRESS=

# --- Tesorería del negocio (conversión de divisas · Opción A pooled+ledger) ---
# Dirección on-chain a la que el usuario transfiere su MXNB al convertir a divisa
# (USDT/EUR/…). El swap se ejecuta en Bitso (pool del negocio) y el saldo en
# divisa se atribuye por-usuario en Supabase (tabla `conversions`). Sin este
# valor, la conversión NO mueve fondos on-chain (el saldo MXNB no baja).
# Tesorería en Arbitrum Sepolia: 0xae0AEAd08f5984E6CD00aB4Fd4e9c569D11b2eaF
NEXT_PUBLIC_TREASURY_ADDRESS=

# --- Base de datos (Supabase · persistencia) ---
# Activa la persistencia en Supabase (true) o usa localStorage (false/vacío).
NEXT_PUBLIC_USE_SUPABASE=false
# Credenciales del proyecto Supabase (SOLO server-side). La service role key
# omite RLS, así que nunca debe llevar prefijo NEXT_PUBLIC_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cliente (opcional) ---
# Solo si el backend vive en otro origen. Vacío = mismo origen (recomendado).
NEXT_PUBLIC_BACKEND_URL=

# --- Etherfuse (KYC + CETES / Stablebonds en Stellar) ---
# Docs: https://docs.etherfuse.com/initial-setup
ETHERFUSE_API_BASE_URL=https://api.sand.etherfuse.com
ETHERFUSE_API_KEY=
ETHERFUSE_ONBOARDING_MODE=programmatic
ETHERFUSE_DEFAULT_BLOCKCHAIN=stellar
ETHERFUSE_WEBHOOK_SECRET=
REYF_ALLOW_ETHERFUSE_RAMP=true
# Webhook: POST https://TU-DOMINIO/api/webhooks/etherfuse (evento kyc_updated)
# Supabase (persistencia única — perfiles, bóvedas, KYC, rate limits)

# --- Pollar (wallet Stellar para CETES) ---
NEXT_PUBLIC_POLLAR_API_KEY=
NEXT_PUBLIC_POLLAR_STELLAR_NETWORK=testnet

# --- DeFindex (bóvedas de rendimiento en Stellar/Soroban · PULSO) ---
# Activa el riel Stellar de bóvedas (si "true", la pantalla de Ahorro usa DeFindex
# en vez del contrato EVM ReyfVaults). El código EVM queda intacto, solo desactivado.
NEXT_PUBLIC_STELLAR_VAULTS=true
# API key del dashboard de DeFindex (api.defindex.io/register → login → crear key).
# Solo servidor: nunca uses el prefijo NEXT_PUBLIC_ para esta variable.
DEFINDEX_API_KEY=
DEFINDEX_BASE_URL=https://api.defindex.io
# Catálogo multi-vault (CETES, USDC, XLM): src/lib/defindex/catalog.ts
# Vault legacy por defecto si no se pasa planId:
NEXT_PUBLIC_DEFINDEX_VAULT_ADDRESS=CBIS5TEMTNNOTBE3WXPQUAGUEDYZZVIWAKTXEQCOUJ34OJJ3FJ5NLF2P
# Asset subyacente: símbolo (solo UI) y decimales (verificado on-chain: 7).
NEXT_PUBLIC_DEFINDEX_ASSET_SYMBOL=CETES
NEXT_PUBLIC_DEFINDEX_ASSET_DECIMALS=7
# false = depósito idle (más barato, recomendado en testnet). true = invierte en Blend en la misma tx.
NEXT_PUBLIC_DEFINDEX_INVEST_ON_DEPOSIT=false
# Margen sobre el resource fee Soroban al preparar la tx (1.15 = +15 %). No uses valores altos.
DEFINDEX_FEE_MARGIN=1.15
